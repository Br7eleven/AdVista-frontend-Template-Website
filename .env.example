# Supabase — get these from your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# (VITE_SUPABASE_PUBLISHABLE_KEY and VITE_SUPABASE_KEY also accepted)

# FreeCryptoAPI — https://freecryptoapi.com/ (optional, for live coin prices)
VITE_FREECRYPTOAPI_KEY=your-api-key-here